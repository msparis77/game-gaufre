{
  "functions": {
    "api/chat.js": { "memory": 256 },
    "api/store.js": { "memory": 256 }
  },
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/store", "destination": "/api/store.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
